{
  "expo": {
    "name": "Autel Pet Hotel",
    "slug": "autel-pet-hotel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D7A7B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.autel.pethotel"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2D7A7B"
      },
      "package": "com.autel.pethotel"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      ["expo-router", { "root": "app" }],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "autel",
    "newArchEnabled": false
  }
}
