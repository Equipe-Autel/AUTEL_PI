{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
    "src/constants/**/*.ts",
    "src/context/**/*.ts",
    "src/context/**/*.tsx",
    "src/types/**/*.ts",
    "src/utils/**/*.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
